                "task": "okoeditor",
                "answer": {
                    "page": "incydenty|notatki|zadania",
                    "id": "32-char-hex-id",
                    "action": "update",
                    "content": "new description text (optional)",
                    "title": "new title (optional)",
                    "done": "YES|NO (only for page zadania, optional)"
                }
            },
            "required_fields": [
                "page",
                "id",
                "action"
            ],
            "optional_fields": [
                "content",
                "title",
                "done"
